{
  "name": "flowmetrics",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "db:up": "docker compose -f infra/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "stack:up": "docker compose -f infra/docker-compose.yml up --build",
    "stack:down": "docker compose -f infra/docker-compose.yml down"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
